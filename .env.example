# One Community — Web Client
#
# Copy this file to `.env.development` (local dev) or `.env.production` (deploy)
# and fill values. The actual env files are gitignored; only this example is tracked.
#
# Full reference: docs/frontend_prd.md §6.6

# ─── Backend connection ──────────────────────────────────────────────
# For local dev: run `make dev` in the backend repo (one-community-1).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Environment flag ────────────────────────────────────────────────
# Accepted: development | staging | production
# Drives Sentry, source-map, and debug-dock behaviour (CLAUDE.md §9.8).
VITE_APP_ENV=development

# ─── Dev conveniences ────────────────────────────────────────────────
# Shows the "Dev mode: OTP is 000000" banner on /signin.
# MUST be false in staging and production.
VITE_OTP_BYPASS_HINT=true

# ─── Mock Service Worker (§13.1.1) ───────────────────────────────────
# When true (dev only), MSW intercepts backend gap endpoints:
#   GET /profile/{id}, POST /ocr, POST /pitch/transcribe, POST /documents/upload.
# Set false when the backend ships all of them.
VITE_MSW_ENABLED=true

# ─── Debug dock (§6.8) ───────────────────────────────────────────────
# Floating dev-mode panel: Requests, Jobs, Session, Flags, Query cache,
# Interactions log. Tree-shaken out of production builds regardless.
VITE_DEBUG_PANEL=true

# ─── Backend gap feature flags (§13.2) ───────────────────────────────
# Flip to true when the backend mounts the corresponding endpoint.
# Each flag routes through an interim service until flipped.
VITE_PROFILE_V1_ENABLED=false         # GET /profile/{id} — §13 G1
VITE_OCR_SERVER_ENABLED=false         # POST /ocr (Google Vision) — §13 G2
VITE_WHISPER_SERVER_ENABLED=false     # POST /pitch/transcribe — §13 G2
VITE_DOCUMENTS_UPLOAD_ENABLED=false   # POST /documents/upload — §13 G3

# ─── Observability (optional) ────────────────────────────────────────
# Leave blank in dev. Populate in staging / production for error reporting.
VITE_SENTRY_DSN=
